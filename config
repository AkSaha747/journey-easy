[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
	autocrlf = false
[remote "upstream"]
	url = https://github.com/Mozahid-DIU/JourneyEasy.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[remote "origin"]
	url = https://github.com/Mozahid-DIU/JourneyEasy.git
	fetch = +refs/heads/*:refs/remotes/origin/*
